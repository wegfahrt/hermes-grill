---
import { Font } from "astro:assets";
import SEO from "../components/SEO.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config/site";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isHome?: boolean;
  schema?: Record<string, unknown>[];
}

const { title, description, ogImage, isHome, schema } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <meta name="generator" content={Astro.generator} />

    {/* Self-hosted fonts (Astro Fonts API). */}
    <Font cssVariable="--ff-marcellus" preload />
    <Font cssVariable="--ff-spectral" preload />
    <Font cssVariable="--ff-pinyon" />

    {/* Enable scroll-reveal styling only when JS is available (no-JS safe). */}
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      isHome={isHome}
      schema={schema}
    />
  </head>
  <body class="flex min-h-dvh flex-col antialiased">
    <Header />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      // Reveal elements as they scroll into view (progressive enhancement).
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.16 },
      );
      document
        .querySelectorAll(".reveal")
        .forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
