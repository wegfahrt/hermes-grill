---
import { siteConfig } from "../config/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-50">
  <!-- Example footer implementation using config data. Adjust structure and styling as needed, but ensure all content is driven by `siteConfig` and not hardcoded. -->
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {/* Brand block */}
      <div class="sm:col-span-2 lg:col-span-2">
        <p class="text-lg font-semibold tracking-tight">{siteConfig.name}</p>
        <p class="mt-2 max-w-sm text-sm text-neutral-500">
          {siteConfig.description}
        </p>
        {siteConfig.business && (
          <div class="mt-4 space-y-1 text-sm text-neutral-500">
            <p>{siteConfig.business.streetAddress}</p>
            <p>{siteConfig.business.postalCode} {siteConfig.business.city}</p>
            {siteConfig.business.phone && (
              <p>
                <a href={`tel:${siteConfig.business.phone}`} class="hover:text-neutral-900 transition-colors">
                  {siteConfig.business.phone}
                </a>
              </p>
            )}
            {siteConfig.business.email && (
              <p>
                <a href={`mailto:${siteConfig.business.email}`} class="hover:text-neutral-900 transition-colors">
                  {siteConfig.business.email}
                </a>
              </p>
            )}
          </div>
        )}
      </div>

      {/* Link columns from config */}
      {siteConfig.footer.columns.map((col) => (
        <div>
          <p class="text-sm font-semibold">{col.heading}</p>
          <ul class="mt-3 space-y-2">
            {col.links.map(({ label, href }) => (
              <li>
                <a
                  href={href}
                  class="text-sm text-neutral-500 transition-colors hover:text-neutral-900"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-10 border-t border-neutral-200 pt-6 text-center text-xs text-neutral-400">
      &copy; {year} {siteConfig.name}. Alle Rechte vorbehalten.
    </div>
  </div>
</footer>
