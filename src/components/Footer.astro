---
import Meander from "./Meander.astro";
import { siteConfig } from "../config/site";

const { name, description, address, phone, hoursShort, footerLinks, legalLinks, owner } =
  siteConfig;
const year = new Date().getFullYear();
---

<footer class="bg-brand-walnut text-[#d9c8b2]">
  <div class="mx-auto w-[min(1180px,92vw)] px-0 pb-9 pt-[70px]">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
      <div>
        <b class="block font-heading text-[26px] tracking-[0.12em] text-[#f6ead7]"
          >{name.toUpperCase()}</b
        >
        <Meander amber class="my-4" />
        <p class="max-w-[30ch] text-[15.5px] text-[#c3b099]">{description}</p>
      </div>

      <div>
        <h4
          class="mb-4 font-body text-[13px] font-semibold uppercase tracking-[0.22em] text-brand-amber-light"
        >
          Adresse
        </h4>
        <address class="not-italic text-[15.5px] text-[#d2c0a9]">
          {address.street}<br />{address.city}
        </address>
        <a
          href={phone.href}
          class="mt-2 block text-[15.5px] text-[#d2c0a9] no-underline transition-colors hover:text-[#f6ead7]"
          >{phone.display}</a
        >
      </div>

      <div>
        <h4
          class="mb-4 font-body text-[13px] font-semibold uppercase tracking-[0.22em] text-brand-amber-light"
        >
          Öffnungszeiten
        </h4>
        {
          hoursShort.map((row) => (
            <div class="flex justify-between gap-3 text-[14.5px]">
              <span>{row.days}</span>
              <span class="text-[#efe0cb]">{row.time}</span>
            </div>
          ))
        }
      </div>

      <div>
        <h4
          class="mb-4 font-body text-[13px] font-semibold uppercase tracking-[0.22em] text-brand-amber-light"
        >
          Entdecken
        </h4>
        {
          footerLinks.map(({ label, href }) => (
            <a
              href={href}
              class="mb-[9px] block text-[15.5px] text-[#d2c0a9] no-underline transition-colors hover:text-[#f6ead7]"
            >
              {label}
            </a>
          ))
        }
      </div>
    </div>

    <div
      class="mt-13 flex flex-wrap justify-between gap-4 border-t border-brand-amber-light/20 pt-[22px] text-[13px] tracking-[0.02em] text-[#9c8a73]"
    >
      <span>© {year} {name} · Inhaberin {owner}</span>
      <div class="flex flex-wrap gap-x-4 gap-y-1">
        {
          legalLinks.map(({ label, href }) => (
            <a
              href={href}
              class="no-underline transition-colors hover:text-[#f6ead7]"
            >
              {label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
