---
import MenuItem from "./MenuItem.astro";
import type { MenuCategory } from "../../data/menu";

interface Props {
  category: MenuCategory;
}

const { category } = Astro.props;
---

<div class="mb-[34px] break-inside-avoid">
  <h3
    class="mb-1 flex items-baseline gap-2.5 border-b-2 border-brand-terracotta pb-[9px] font-heading text-[23px] text-brand-ink"
  >
    <span class="menu-key" aria-hidden="true"></span>
    {category.title}
  </h3>
  {
    category.note && (
      <p class="mt-2.5 font-body text-[14px] italic leading-[1.5] text-brand-ink-soft">
        {category.note}
      </p>
    )
  }
  <div class="mt-3.5">
    {category.items.map((item) => <MenuItem item={item} />)}
  </div>
</div>
