---
export const prerender = true;

import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Meander from "../components/Meander.astro";
import SectionHead from "../components/SectionHead.astro";
import MapEmbed from "../components/MapEmbed.astro";
import { siteConfig } from "../config/site";

import innenbereich from "../assets/images/innenbereich.jpg";
import aussenbereich from "../assets/images/außenbereich.jpg";
import vorspeisenteller from "../assets/images/vorspeisenteller.jpg";
import grillteller from "../assets/images/grillteller.jpg";
import nebenzimmer from "../assets/images/nebenzimmer.jpg";

const { phone, hours } = siteConfig;

// Curated grill highlights for the landing teaser (full list lives on /speisekarte).
const grillHighlights = [
  { name: "Lammkoteletts", desc: "Zarte Lammkrone, mit Beilagen & Salat", price: "32,50 €" },
  { name: "Lammfilet am Spieß", desc: "Saftiges Filet vom Spieß, mit Beilagen", price: "32,50 €" },
  { name: "Gyros vom Drehspieß", desc: "Mit Tomaten, Zwiebeln & Tsatsiki", price: "17,50 €" },
  { name: "Bauern Platte", desc: "Spieß, Steak, Lammkotelett, Suzukakia & Feta", price: "23,50 €" },
];

const galleryOverlay =
  "absolute inset-x-0 bottom-0 m-0 bg-gradient-to-t from-[rgba(30,20,13,0.78)] to-transparent px-[18px] pb-3.5 pt-[30px] font-body text-[15px] italic text-[#fbf3e6]";
---

<BaseLayout title={siteConfig.name} isHome>
  {/* ===== HERO ===== */}
  <section
    class="relative flex min-h-[min(90vh,800px)] items-center justify-center overflow-hidden text-center text-[#fbf3e6]"
  >
    <Image
      src={innenbereich}
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 h-full w-full scale-105 object-cover"
    />
    <div
      class="absolute inset-0 bg-[radial-gradient(120%_100%_at_50%_30%,rgba(47,33,24,0.30),rgba(30,20,13,0.72)_78%),linear-gradient(to_bottom,rgba(30,20,13,0.55),rgba(30,20,13,0.28)_40%,rgba(30,20,13,0.78))]"
    >
    </div>

    <div class="relative z-10 max-w-[880px] px-5 py-10">
      <span
        class="inline-block rounded-sm border border-brand-amber-light/50 px-5 py-2 font-body font-medium uppercase tracking-[0.32em] text-[12.5px] text-brand-amber-light"
        >Ταβέρνα · Mannheim</span
      >
      <h1
        class="mt-6 font-heading text-[clamp(40px,9vw,104px)] tracking-[0.04em] text-[#fbf3e6] [text-shadow:0_2px_30px_rgba(0,0,0,0.45)]"
      >
        {siteConfig.name}
      </h1>
      <p
        class="mt-3 font-body text-[clamp(19px,2.6vw,26px)] italic text-[#f0dfc8]"
      >
        Griechische Spezialitäten in gemütlicher Atmosphäre
      </p>
      <div class="mt-9 flex flex-wrap justify-center gap-4">
        <Button href="/speisekarte" variant="solid">Zur Speisekarte</Button>
        <Button href={phone.href} variant="ghost">Tisch reservieren</Button>
      </div>
    </div>

    <a
      href="#welcome"
      aria-label="Weiter nach unten"
      class="animate-bob absolute bottom-6 left-1/2 z-10 -translate-x-1/2 text-[22px] text-[#fbf3e6]/70 no-underline"
      >▾</a
    >
  </section>

  {/* ===== INFO RIBBON ===== */}
  <div class="bg-brand-terracotta text-[#fbeede]">
    <div
      class="mx-auto flex w-[min(1180px,92vw)] flex-wrap items-center justify-center gap-x-[46px] gap-y-[30px] py-[17px] text-[15px] tracking-[0.02em]"
    >
      <span><b class="font-semibold">Mittwoch – Sonntag</b> · 11:30–14:00 & 17:00–23:00</span>
      <span class="opacity-50" aria-hidden="true">●</span>
      <span><b class="font-semibold">Montag & Dienstag</b> Ruhetag</span>
      <span class="opacity-50" aria-hidden="true">●</span>
      <span>Reservierung: <b class="font-semibold">{phone.display}</b></span>
    </div>
  </div>

  {/* ===== WELCOME ===== */}
  <section id="welcome" class="bg-brand-cream py-16 sm:py-[92px]">
    <div
      class="mx-auto grid w-[min(1180px,92vw)] grid-cols-1 items-center gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16"
    >
      <div class="reveal">
        <span
          class="font-body font-medium uppercase tracking-[0.34em] text-[12.5px] text-brand-terracotta"
          >Καλώς ορίσατε</span
        >
        <h2
          class="mb-5 mt-3.5 font-heading text-[clamp(30px,4vw,44px)] text-brand-ink"
        >
          Herzlich willkommen<br />bei Hermes
        </h2>
        <p class="mb-[18px] text-brand-ink-soft">
          Wenn Sie griechische Spezialitäten in gemütlicher Atmosphäre genießen
          möchten, sind Sie bei uns genau richtig. Bei uns erwartet Sie beste
          Qualität, eine entspannte Atmosphäre und freundliches Personal.
        </p>
        <p class="mb-[18px] text-brand-ink-soft">
          Vom Drehspieß über zartes Weidelamm bis zu frischem Fisch und Meze –
          wir kochen mit Herz und nach echten griechischen Rezepten.
        </p>
        <Meander class="my-6" />
        <p class="font-script text-[38px] leading-none text-brand-terracotta">
          Familie Milona
        </p>
        <p
          class="mt-1.5 text-[14px] uppercase tracking-[0.12em] text-brand-ink-soft"
        >
          {siteConfig.owner} · Inhaberin
        </p>
      </div>

      <div class="reveal relative">
        <Image
          src={vorspeisenteller}
          alt="Gemischter griechischer Vorspeisenteller mit Meze"
          class="h-[420px] w-full rounded-[3px] object-cover shadow-warm sm:h-[560px]"
        />
        <div
          class="absolute -bottom-4 -right-4 left-4 top-4 -z-10 hidden rounded-[3px] border-[1.5px] border-brand-stone sm:block"
        >
        </div>
      </div>
    </div>
  </section>

  {/* ===== GRILL FEATURE ===== */}
  <section class="bg-brand-walnut py-16 text-[#f1e3cf] sm:py-[92px]">
    <div
      class="mx-auto grid w-[min(1180px,92vw)] grid-cols-1 items-center gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:gap-[60px]"
    >
      <div class="reveal order-1 lg:order-none">
        <Image
          src={grillteller}
          alt="Lammkoteletts und Spieß vom Holzkohlegrill"
          class="h-[420px] w-full rounded-[3px] object-cover shadow-[0_24px_60px_-28px_rgba(0,0,0,0.7)] lg:h-[600px]"
        />
      </div>

      <div class="reveal">
        <span
          class="font-body font-medium uppercase tracking-[0.34em] text-[12.5px] text-brand-amber-light"
          >Vom Holzkohlegrill</span
        >
        <h2
          class="mt-3.5 font-heading text-[clamp(30px,4.4vw,46px)] text-[#f6ead7]"
        >
          Spezialitäten<br />vom Grill
        </h2>
        <p class="my-[18px] text-[19px] text-[#cdb89c]">
          Nur neuseeländisches Weidelamm und frisches Angus-Rinderfilet –
          serviert mit griechischen Ofenkartoffeln, grünen Bohnen und
          marktfrischem Salat.
        </p>
        <ul class="mb-8 list-none p-0">
          {
            grillHighlights.map((dish) => (
              <li class="flex items-baseline gap-3.5 border-b border-brand-amber-light/20 py-[15px]">
                <span>
                  <span class="font-heading text-[21px] text-[#f6ead7]">
                    {dish.name}
                  </span>
                  <span class="mt-[3px] block font-body text-[14.5px] text-[#b8a589]">
                    {dish.desc}
                  </span>
                </span>
                <span class="-translate-y-[5px] flex-1 border-b border-dotted border-brand-amber-light/40" />
                <span class="whitespace-nowrap font-heading text-[20px] text-brand-amber-light">
                  {dish.price}
                </span>
              </li>
            ))
          }
        </ul>
        <Button href="/speisekarte" variant="outline-amber"
          >Ganze Speisekarte ansehen</Button
        >
      </div>
    </div>
  </section>

  {/* ===== GALLERY ===== */}
  <section class="bg-brand-cream-deep py-16 sm:py-[92px]">
    <div class="mx-auto w-[min(1180px,92vw)]">
      <SectionHead eyebrow="Atmosphäre" center class="reveal mb-13">
        Bei uns zu Gast
      </SectionHead>

      <div
        class="reveal grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:auto-rows-[200px]"
      >
        <figure
          class="group relative h-[220px] overflow-hidden rounded-[3px] sm:col-span-2 sm:h-auto lg:row-span-2"
        >
          <Image
            src={innenbereich}
            alt="Gemütlicher Gastraum mit Natursteinwand"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <figcaption class={galleryOverlay}>
            Unser Gastraum mit Natursteinwand & Kerzenlicht
          </figcaption>
        </figure>

        <figure
          class="group relative h-[220px] overflow-hidden rounded-[3px] sm:col-span-2 sm:h-auto"
        >
          <Image
            src={aussenbereich}
            alt="Begrünte Terrasse mit Olivenbäumen"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <figcaption class={galleryOverlay}>
            Sommerterrasse unter Olivenbäumen
          </figcaption>
        </figure>

        <figure
          class="group relative h-[220px] overflow-hidden rounded-[3px] sm:h-auto"
        >
          <Image
            src={vorspeisenteller}
            alt="Gemischter Vorspeisenteller"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <figcaption class={galleryOverlay}>Meze-Vorspeisen</figcaption>
        </figure>

        <figure
          class="group relative h-[220px] overflow-hidden rounded-[3px] sm:h-auto"
        >
          <Image
            src={nebenzimmer}
            alt="Festlich gedecktes Nebenzimmer"
            class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          <figcaption class={galleryOverlay}>Nebenzimmer für Feste</figcaption>
        </figure>
      </div>
    </div>
  </section>

  {/* ===== FESTE / FEIERN ===== */}
  <section
    id="feiern"
    class="relative overflow-hidden text-[#fbf3e6]"
  >
    <Image
      src={nebenzimmer}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-[center_28%]"
    />
    <div
      class="absolute inset-0 bg-[linear-gradient(105deg,rgba(40,26,16,0.92)_28%,rgba(40,26,16,0.55)_62%,rgba(40,26,16,0.3))]"
    >
    </div>
    <div class="relative z-10 mx-auto w-[min(1180px,92vw)] py-[70px] sm:py-[104px]">
      <div class="reveal max-w-[540px]">
        <span
          class="font-body font-medium uppercase tracking-[0.34em] text-[12.5px] text-brand-amber-light"
          >Feiern & Festlichkeiten</span
        >
        <h2
          class="mt-3.5 font-heading text-[clamp(30px,4.4vw,46px)] text-[#fbf3e6]"
        >
          Ihr Fest bei Hermes
        </h2>
        <p class="my-[22px] text-[19px] text-[#ecdcc6]">
          Für größere oder kleinere Festlichkeiten bieten wir Ihnen ein schönes
          Nebenzimmer sowie den separaten Anbau – ganz für Sie und Ihre Gäste.
          Sprechen Sie uns einfach an, wir planen Ihre Feier gemeinsam.
        </p>
        <Button href={phone.href} variant="solid"
          >Anfragen unter {phone.display}</Button
        >
      </div>
    </div>
  </section>

  {/* ===== BESUCH / KONTAKT ===== */}
  <section id="kontakt" class="bg-brand-cream py-16 sm:py-[92px]">
    <div class="mx-auto w-[min(1180px,92vw)]">
      <SectionHead eyebrow="Besuchen Sie uns" center class="reveal mb-13">
        Öffnungszeiten & Kontakt
      </SectionHead>

      <div
        class="grid grid-cols-1 items-stretch gap-[30px] lg:grid-cols-[0.82fr_1.18fr]"
      >
        <div class="flex flex-col gap-[30px]">
          <div
            class="reveal flex-1 rounded border border-brand-line bg-brand-paper p-8 shadow-[0_14px_30px_-26px_rgba(47,33,24,0.5)] sm:px-[34px] sm:py-[38px]"
          >
            <span class="text-[22px] text-brand-terracotta" aria-hidden="true"
              >◷</span
            >
            <h3 class="mb-[18px] mt-3.5 font-heading text-[25px] text-brand-ink">
              Öffnungszeiten
            </h3>
            {
              hours.map((row) => (
                <div
                  class:list={[
                    "flex justify-between gap-3.5 border-b border-dotted border-brand-line py-[9px] text-[16px]",
                    row.rest && "font-medium text-brand-terracotta",
                  ]}
                >
                  <span class={row.rest ? "" : "text-brand-ink-soft"}>
                    {row.days}
                  </span>
                  <span>{row.time}</span>
                </div>
              ))
            }
          </div>

          <div
            class="reveal flex-1 rounded border border-brand-line bg-brand-paper p-8 shadow-[0_14px_30px_-26px_rgba(47,33,24,0.5)] sm:px-[34px] sm:py-[38px]"
          >
            <span class="text-[22px] text-brand-terracotta" aria-hidden="true"
              >☎</span
            >
            <h3 class="mb-[18px] mt-3.5 font-heading text-[25px] text-brand-ink">
              Reservierung
            </h3>
            <p class="my-[6px] font-heading text-[28px] text-brand-ink">
              {phone.display}
            </p>
            <p class="text-[15px] text-brand-ink-soft">
              Wir empfehlen eine Reservierung – besonders am Wochenende.
            </p>
            <Button href={phone.href} variant="solid" class="mt-[18px]"
              >Jetzt anrufen</Button
            >
          </div>
        </div>

        <div class="reveal">
          <MapEmbed />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
