---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout title="Seite nicht gefunden">
  <section
    class="mx-auto flex w-[min(1180px,92vw)] flex-col items-center justify-center py-32 text-center"
  >
    <p
      class="font-body font-medium uppercase tracking-[0.34em] text-[12.5px] text-brand-terracotta"
    >
      Fehler 404
    </p>
    <h1 class="mt-3 font-heading text-[clamp(32px,6vw,56px)] text-brand-ink">
      Seite nicht gefunden
    </h1>
    <p class="mt-4 max-w-md text-brand-ink-soft">
      Die angeforderte Seite existiert nicht oder wurde verschoben.
    </p>
    <Button href="/" variant="solid" class="mt-8">Zur Startseite</Button>
  </section>
</BaseLayout>
