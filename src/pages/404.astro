---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Seite nicht gefunden">
  <section class="mx-auto flex max-w-6xl flex-col items-center justify-center px-6 py-32 text-center">
    <p class="text-sm font-medium text-neutral-400">404</p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">
      Seite nicht gefunden
    </h1>
    <p class="mt-4 max-w-md text-neutral-500">
      Die angeforderte Seite existiert nicht oder wurde verschoben.
    </p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-neutral-900 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-neutral-700"
    >
      Zur Startseite
    </a>
  </section>
</BaseLayout>
